def _mode_instructions(mode: ReadingMode) -> str:
    if mode == "short":
        return "Длина ответа: кратко, без лишней воды."
    if mode == "deep":
        return "Длина ответа: глубоко, с нюансами и связями между позициями."
    return "Длина ответа: подробно, но структурировано."


def _style_instructions(style: ReadingStyle) -> str:
    if style == "psychological":
        return "Стиль: психологический — акцент на мотивах, границах, эмоциях и саморегуляции."
    if style == "practical":
        return "Стиль: практический — акцент на конкретных шагах, ресурсах и рисках."
    if style == "normal_ai":
        return "Стиль: обычный ИИ — прямой, без лишней методологии."
    if style == "predictor":
        return "Стиль: предсказатель — акцент на тенденциях и вероятном развитии (без гарантий)."
    return "Стиль: мягкий — тёплый, поддерживающий, без морализаторства."


def _topic_label(topic: QuestionTopic) -> str:
    return {
        "love": "любовь и отношения",
        "career": "карьера и работа",
        "money": "деньги и финансы",
        "decision": "решения и выбор",
        "self": "самооценка, границы, внутреннее состояние",
        "general": "общая тема",
    }[topic]


def _cards_block(cards: list[DrawnCard]) -> str:
    lines: list[str] = []
    for i, c in enumerate(cards, start=1):
        lines.append(
            f"{i}. Позиция: {c.position_name}. Карта: {c.card}. Ориентация: {c.orientation}."
        )
    return "\n".join(lines)


def build_primary_reading_messages(
    *,
    spread_title: str,
    spread_description: str,
    cards: list[DrawnCard],
    user_question: str,
    topic: QuestionTopic,
    reading_mode: ReadingMode,
    reading_style: ReadingStyle,
) -> list[dict[str, str]]:
    """Сообщения для первичной интерпретации расклада."""

    user = (
        f"Расклад: {spread_title}\n"
        f"Кратко о раскладе: {spread_description}\n"
        f"Тема вопроса (эвристика): {_topic_label(topic)}\n"
        f"Вопрос пользователя:\n{user_question}\n\n"
        f"Выпавшие карты (не меняй их):\n{_cards_block(cards)}\n\n"
        f"{_mode_instructions(reading_mode)}\n"
        f"{_style_instructions(reading_style)}\n"
        "Сформируй интерпретацию строго по структуре из системной инструкции."
    )
    return [
        {"role": "system", "content": _system_prompt_for_style(reading_style)},
        {"role": "user", "content": user},
    ]


def build_followup_messages(
    *,
    spread_title: str,
    spread_description: str,
    cards: list[DrawnCard],
    prior_messages: list[dict[str, str]],
    followup_question: str,
    topic: QuestionTopic,
    reading_mode: ReadingMode,
    reading_style: ReadingStyle,
) -> list[dict[str, str]]:
    """Сообщения для уточнения по тому же раскладу (без новых карт)."""

    anchor = (
        "Контекст расклада (карты фиксированы, не меняй их):\n"
        f"{spread_title}. {spread_description}\n"
        f"{_cards_block(cards)}\n"
        f"Тема: {_topic_label(topic)}\n"
        f"{_mode_instructions(reading_mode)}\n"
        f"{_style_instructions(reading_style)}\n"
        "Ответь на уточняющий вопрос, опираясь на тот же расклад и предыдущий диалог. "
        "Сохрани структуру ответа (4 раздела с заголовками). "
        f"Уточняющий вопрос:\n{followup_question}"
    )

    messages: list[dict[str, str]] = [{"role": "system", "content": _system_prompt_for_style(reading_style)}]
    for m in prior_messages:
        if m.get("role") in ("user", "assistant") and m.get("content"):
            messages.append({"role": m["role"], "content": m["content"]})
    messages.append({"role": "user", "content": anchor})
    return messages


