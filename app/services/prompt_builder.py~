def _format_free_step_cards(cards: list[dict[str, Any]]) -> str:
    lines: list[str] = []
    for i, c in enumerate(cards, start=1):
        lines.append(
            f"{i}. {c.get('position_name', '')}: {c.get('card', '')} — {c.get('orientation', '')}."
        )
    return "\n".join(lines)


def _format_free_history_for_prompt(history: list[dict[str, Any]]) -> tuple[str, str]:
    """Компактные старые шаги и подробные последние 5."""

    if not history:
        return "", ""

    older = history[:-5] if len(history) > 5 else []
    recent = history[-5:]

    compact_lines: list[str] = []
    for step in older:
        t = int(step.get("turn", 0))
        sz = int(step.get("spread_size", 0))
        q = str(step.get("question", ""))[:100]
        compact_lines.append(f"Шаг {t}: {sz} карт(ы). Вопрос: {q}{'…' if len(str(step.get('question', ''))) > 100 else ''}")
    compact_block = "Ранние шаги (кратко):\n" + "\n".join(compact_lines) if compact_lines else ""

    recent_blocks: list[str] = []
    for step in recent:
        interp = str(step.get("interpretation", ""))
        if len(interp) > 1800:
            interp = interp[:1797] + "…"
        recent_blocks.append(
            f"--- Шаг {step.get('turn')} ({step.get('spread_size')} карт) ---\n"
            f"Вопрос: {step.get('question', '')}\n"
            f"Карты:\n{_format_free_step_cards(list(step.get('cards') or []))}\n"
            f"Интерпретация:\n{interp}\n"
        )
    recent_block = "Последние шаги (полностью):\n" + "\n".join(recent_blocks)
    return compact_block, recent_block


def _append_sliding_turns(
    messages: list[dict[str, str]], sliding_memory: list[dict[str, str]]
) -> None:
    for m in sliding_memory:
        if m.get("role") in ("user", "assistant") and m.get("content"):
            messages.append({"role": str(m["role"]), "content": str(m["content"])})


def build_free_session_messages(
    *,
    session_topic: str,
    history: list[dict[str, Any]],
    sliding_memory: list[dict[str, str]],
    current_cards: list[DrawnCard],
    current_question: str,
    topic: QuestionTopic,
    reading_mode: ReadingMode,
    reading_style: ReadingStyle,
) -> list[dict[str, str]]:
    """Промпт для шага свободной сессии: краткая история шагов + скользящая память реплик."""

    compact, recent = _format_free_history_for_prompt(history)
    user_parts = [
        f"Общая тема сессии (держи её как красную нить):\n{session_topic}\n",
        f"Тема текущего вопроса (эвристика): {_topic_label(topic)}\n",
    ]
    if compact:
        user_parts.append(compact + "\n")
    if recent.strip():
        user_parts.append(recent + "\n")
    user_parts.extend(
        [
            "Текущий мини-расклад (карты фиксированы):\n"
            f"{_cards_block(current_cards)}\n\n"
            f"Вопрос к этому шагу:\n{current_question}\n\n"
            f"{_mode_instructions(reading_mode)}\n"
            f"{_style_instructions(reading_style)}\n"
            "Дай ответ строго по структуре из системной инструкции.",
        ]
    )
    user_content = "\n".join(user_parts)
    messages: list[dict[str, str]] = [
        {"role": "system", "content": _free_session_system_prompt_for_style(reading_style)},
    ]
    _append_sliding_turns(messages, sliding_memory)
    messages.append({"role": "user", "content": user_content})
    return messages


