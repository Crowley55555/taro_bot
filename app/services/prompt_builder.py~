def build_reading_discussion_messages(
    *,
    spread_title: str,
    spread_description: str,
    cards: list[DrawnCard],
    original_question: str,
    last_interpretation: str,
    discussion_history: list[dict[str, str]],
    new_message: str,
    topic: QuestionTopic,
    reading_mode: ReadingMode,
    reading_style: ReadingStyle,
) -> list[dict[str, str]]:
    """Обсуждение уже выпавшего расклада без новых карт."""

    ctx = (
        "Контекст (карты фиксированы, не меняй и не добавляй карты):\n"
        f"Название расклада: {spread_title}\n"
        f"Описание: {spread_description}\n"
        f"Исходный вопрос к раскладу:\n{original_question}\n\n"
        f"Выпавшие карты:\n{_cards_block(cards)}\n\n"
        f"Последняя интерпретация (опорная):\n{last_interpretation}\n"
    )
    messages: list[dict[str, str]] = [
        {"role": "system", "content": _discussion_system_prompt_for_style(reading_style)},
        {"role": "user", "content": ctx},
        {
            "role": "assistant",
            "content": "Принято: опираюсь на этот расклад и уже сказанное, новых карт не будет.",
        },
    ]
    for m in discussion_history:
        if m.get("role") in ("user", "assistant") and m.get("content"):
            messages.append({"role": str(m["role"]), "content": str(m["content"])})
    messages.append(
        {
            "role": "user",
            "content": (
                f"Новое сообщение пользователя (это обсуждение, не новый расклад):\n{new_message}\n\n"
                f"Тема (эвристика): {_topic_label(topic)}\n"
                f"{_mode_instructions(reading_mode)}\n"
                f"{_style_instructions(reading_style)}\n"
                "Ответь по структуре из системной инструкции."
            ),
        }
    )
    return messages


