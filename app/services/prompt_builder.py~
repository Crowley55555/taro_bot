    return (
        "Ты — внимательный помощник по символическому Таро. Отвечай ТОЛЬКО на русском. "
        "Обсуждение текущего мини-расклада без новых карт; акцент на тенденциях и вероятном развитии "
        "по уже открытым картам — мягко, без гарантий и опасных утверждений.\n"
        "Структура (с заголовками):\n"
        "1) Вопрос и прогнозная нить\n2) Карты и тенденции\n3) Уточнение понимания\n4) Ориентир\n"
    )


def _free_discussion_system_prompt_for_style(style: ReadingStyle) -> str:
    if style == "normal_ai":
        return _free_discussion_system_prompt_normal_ai()
    if style == "predictor":
        return _free_discussion_system_prompt_predictor()
    return _free_discussion_system_prompt_default()


def build_free_discussion_messages(
    *,
    session_topic: str,
    session_history: list[dict[str, Any]],
    sliding_memory: list[dict[str, str]],
    current_cards: list[DrawnCard],
    last_step_interpretation: str,
    last_step_question: str,
    new_message: str,
    topic: QuestionTopic,
    reading_mode: ReadingMode,
    reading_style: ReadingStyle,
) -> list[dict[str, str]]:
    """Обсуждение текущего шага свободной сессии: краткая история шагов + скользящая память реплик."""

    compact, recent = _format_free_history_for_prompt(session_history)
    user_parts = [
        f"Общая тема сессии:\n{session_topic}\n",
        f"Тема сообщения (эвристика): {_topic_label(topic)}\n",
    ]
    if compact:
        user_parts.append(compact + "\n")
    if recent.strip():
        user_parts.append(recent + "\n")
    user_parts.extend(
        [
            "Текущий мини-расклад (карты на столе, без новых карт):\n"
            f"{_cards_block(current_cards)}\n",
            f"Вопрос к этому шагу (как был задан до толкования):\n{last_step_question}\n",
            f"Толкование этого шага (опорное):\n{last_step_interpretation}\n",
            "Дальше — только обсуждение этих карт в контексте сессии.\n",
            f"Новое сообщение пользователя (обсуждение, не новый расклад):\n{new_message}\n",
            f"{_mode_instructions(reading_mode)}\n",
            f"{_style_instructions(reading_style)}\n",
            "Ответь по структуре из системной инструкции.",
        ]
    )
    user_content = "\n".join(user_parts)
    messages: list[dict[str, str]] = [
        {"role": "system", "content": _free_discussion_system_prompt_for_style(reading_style)},
    ]
    _append_sliding_turns(messages, sliding_memory)
    messages.append({"role": "user", "content": user_content})
    return messages