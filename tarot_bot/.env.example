TELEGRAM_BOT_TOKEN=
# Таймаут HTTP к api.telegram.org (сек), если при старте видите TimedOut — увеличьте (например 60) или проверьте VPN/прокси
TELEGRAM_HTTP_TIMEOUT_SECONDS=30

DEFAULT_LLM_PROVIDER=openrouter
DEFAULT_OPENROUTER_MODEL=qwen/qwen3.6-plus:free
DEFAULT_OPENAI_MODEL=gpt-4o-mini
DEFAULT_GIGACHAT_MODEL=GigaChat-2-Max
DEFAULT_YANDEX_MODEL=yandexgpt/latest

OPENROUTER_API_KEY=
# Включить reasoning в запросах OpenRouter (при ошибке 400/422 — один повтор без reasoning)
OPENROUTER_ENABLE_REASONING=false
OPENAI_API_KEY=

GIGACHAT_AUTH_KEY=
GIGACHAT_CLIENT_ID=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_VERIFY_SSL=true
GIGACHAT_USE_OPENAI_COMPAT=false
GIGACHAT_BASE_URL=
GIGACHAT_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_API_URL=https://gigachat.devices.sberbank.ru/api/v1/chat/completions

YANDEX_API_KEY=
YANDEX_CATALOG_ID=
YANDEX_BASE_URL=https://llm.api.cloud.yandex.net/v1

SQLITE_PATH=./tarot_bot.db
# Таймаут ожидания блокировки SQLite (секунды)
SQLITE_CONNECT_TIMEOUT_SECONDS=30
DEBUG=false
ADMIN_USER_IDS=

HTTP_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=3
LLM_RETRY_BACKOFF_BASE=1.5
MAX_FOLLOWUP_PER_READING=5
# Макс. сообщений в диалоге follow-up (после усечения)
MAX_DIALOG_MESSAGES=8
# Макс. циклов «расклад + толкование» в режиме «Свободный расклад»
MAX_FREE_SESSION_TURNS=35
# Макс. сообщений в истории обсуждения текущего расклада (user+assistant, после усечения)
MAX_DISCUSSION_MESSAGES=12
QUESTION_MIN_LEN=30
QUESTION_MAX_LEN=1200

# Пояснения по сессии, истории, Docker и reasoning — в README.md
